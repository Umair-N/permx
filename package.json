{
  "name": "permx-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun --filter '@permx/core' build && bun --filter '@permx/react' build",
    "test": "bun --filter '@permx/core' test && bun --filter '@permx/react' test",
    "typecheck": "bun --filter '@permx/core' typecheck && bun --filter '@permx/react' typecheck",
    "lint": "bun --filter '@permx/core' lint && bun --filter '@permx/react' lint",
    "build:core": "bun --filter '@permx/core' build",
    "build:react": "bun --filter '@permx/react' build",
    "test:core": "bun --filter '@permx/core' test",
    "test:react": "bun --filter '@permx/react' test"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
